# ============================================
# AI Email Automation Assistant - Environment
# ============================================
# Copy this file to `.env.local` and fill in your real keys.
# NEVER commit .env.local to git.

# --- Groq AI (https://console.groq.com) ---
# Free tier; used for categorization, sentiment, and reply generation
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_NEW_KEY

# --- Google OAuth (https://console.cloud.google.com) ---
# Create OAuth 2.0 Client ID -> Web application
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Enable Gmail API in the same project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth (generate with: openssl rand -base64 32) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- Notion (https://www.notion.so/my-integrations) ---
# Create an internal integration, then share a database with it
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Slack (https://api.slack.com/apps -> Incoming Webhooks) ---
# Optional - leave blank to disable Slack alerts
SLACK_WEBHOOK_URL=

# --- Cron security (any random string) ---
CRON_SECRET=change-me-to-a-random-string
